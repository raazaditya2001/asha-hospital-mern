# MongoDB connection string (MongoDB Atlas or local)
MONGO_URI="mongodb://localhost:27017/ashaHospital"
# Server
PORT=5000
NODE_ENV=production

# Comma separated list of allowed origins for CORS (your deployed frontend URL)
CLIENT_URL=http://localhost:5173

# Simple admin key used to protect the GET (list) endpoints for appointments/contacts
ADMIN_API_KEY=change_this_to_a_long_random_secret
